<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Log in - learnEnglish</title>
    <link rel="stylesheet" type="text/css" href="/styles/typography.css" />
    <link rel="stylesheet" type="text/css" href="/styles/log-reg-forgot.css" />
  </head>
  <body>
    <div>
      <!-- Login Form Container -->
      <div class="container">
        <div class="tab-container">
          <a href="/login" class="tab active" id="tab-login">Log in</a>
          <a href="/register" class="tab" id="tab-signup">Sign up</a>
        </div>
        
        <header class="page-header">Log in to your learnEnglish account</header>
        <!-- Error Message -->
        <% if (messages && messages.error) { %>
          <div class="error-message">
            <%= messages.error %>
          </div>
        <% } %>

        <!-- Login Form -->
        <form action="/login" method="POST" class="form-container">
          <!-- Email Field -->
          <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <input
              type="email"
              id="email"
              class="form-control form-input"
              name="email"
              placeholder="me@myemail.com"
              required
            />
          </div>

          <!-- Password Field -->
          <div class="form-group">
            <label for="password" class="form-label">Password</label>
            <input
              type="password"
              id="password"
              class="form-control form-input"
              name="password"
              placeholder="Enter your password"
              required
            />
          </div>

          <!-- Submit Button -->
          <button type="submit" class="form-button primary">Log in</button>
        </form>

        <!-- Links -->
        <div class="forgot-password">
          <a href="">Forgot your password? (Currently not available to use)</a>
        </div>
        <div class="return-home">
          <a href="/" class="return-home-btn">← Return to Home</a>
        </div>
      </div>
    </div>
  </body>
</html>
