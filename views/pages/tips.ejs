<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tips - learnEnglish</title>
    <link rel="stylesheet" href="/styles/typography.css">
    <link rel="stylesheet" href="/styles/tips.css">
</head>

<body class="page-tips">
    <header class="header"></header>
    <main class="tips-main">
        <section class="tips-header">
          <h1 class="text-center">IELTS Preparation Tips</h1>
          <p class="text-center">Click a skill to explore colorful tips and strategies!</p>
        </section>
      
        <section class="tips-tabs">
          <div class="tabs-container">
            <button class="tab active" data-skill="listening" style="background: #3498db;">🎧 Listening</button>
            <button class="tab" data-skill="reading" style="background: #2ecc71;">📖 Reading</button>
            <button class="tab" data-skill="writing" style="background: #f1c40f;">✍️ Writing</button>
            <button class="tab" data-skill="speaking" style="background: #e74c3c;">🗣️ Speaking</button>
          </div>
        </section>
      
        <section class="tips-content">
          <!-- Listening Tips -->
          <div id="listening" class="tips-cards active" style="background: linear-gradient(135deg, #3498db, #85c1e9);">
            <h2 class="text-center">Listening Tips</h2>
            <div class="cards-grid">
              <div class="card">Familiarize yourself with different accents.</div>
              <div class="card">Focus on keywords, not every word.</div>
              <div class="card">Practice note-taking while listening.</div>
              <div class="card">Pay attention to synonyms in audio and questions.</div>
            </div>
          </div>
      
          <!-- Reading Tips -->
          <div id="reading" class="tips-cards" style="background: linear-gradient(135deg, #2ecc71, #58d68d);">
            <h2 class="text-center">Reading Tips</h2>
            <div class="cards-grid">
              <div class="card">Skim the passage for main ideas.</div>
              <div class="card">Identify keywords in questions.</div>
              <div class="card">Spend only 20 minutes per passage.</div>
              <div class="card">Understand question types like True/False/Not Given.</div>
            </div>
          </div>
      
          <!-- Writing Tips -->
          <div id="writing" class="tips-cards" style="background: linear-gradient(135deg, #f1c40f, #f9e79f);">
            <h2 class="text-center">Writing Tips</h2>
            <div class="cards-grid">
              <div class="card">Understand Task 1 (report) and Task 2 (essay).</div>
              <div class="card">Use varied sentence structures and vocabulary.</div>
              <div class="card">Plan your essay for 5 minutes before starting.</div>
              <div class="card">Avoid repeating words; use synonyms effectively.</div>
            </div>
          </div>
      
          <!-- Speaking Tips -->
          <div id="speaking" class="tips-cards" style="background: linear-gradient(135deg, #e74c3c, #f5b7b1);">
            <h2 class="text-center">Speaking Tips</h2>
            <div class="cards-grid">
              <div class="card">Speak clearly and confidently, even if you make mistakes.</div>
              <div class="card">Practice answering common IELTS topics.</div>
              <div class="card">Use a mix of tenses to show grammar range.</div>
              <div class="card">Focus on natural communication, not memorization.</div>
            </div>
          </div>
        </section>
      </main>
      
    <footer class="footer"></footer>
    <script src="/scripts/header.js"></script>
    <script src="/scripts/footer.js"></script>
    <script src="/scripts/tips.js"></script>
</body>

</html>
