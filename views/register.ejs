<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/styles/typography.css" />
  <link rel="stylesheet" href="/styles/log-reg-forgot.css" />
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <title>Sign Up - learnEnglish</title>
</head>
<body>
  <div class="container">
    <div class="tab-container">
      <a href="/login" class="tab" id="tab-login">Log in <span class="material-icons">login</span></a>
      <a href="/register" class="tab active" id="tab-signup">Sign up <span class="material-icons">person_add</span></a>
    </div>

    <div class="signup-header">
      <h1 id="step-title">Set up your new account to access</h1>
      <% if (messages.error) { %>
        <div class="error-message">
            <%= messages.error %>
        </div>
    <% } %>
    </div>

    <form action="/register" method="POST" class="form-container">
      <div class="form-group">
        <label for="name"><span class="material-icons">badge</span>  Username</label>
        <input
          type="text"
          id="name"
          name="name"
          class="form-control"
          placeholder="Enter your name"
          required
        />
      </div>
      
        <div class="form-group">
          <label for="email"><span class="material-icons">mail</span>  Email address</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-control"
            placeholder="Enter your email"
            required oninput="checkEmailAvailability()"
          />
          <div id="email-error" class="error-message"></div>
          <div id="email-valid" class="valid-message"></div>
        </div>
      
        <div class="form-group">
          <label for="gender"><span class="material-icons">wc</span>  Gender</label>
          <select id="gender" name="gender" class="form-control" required>
            <option value="" disabled selected>Select your gender</option>
            <option value="Male">Male</option>
            <option value="Female">Female</option>
            <option value="Other">Other</option>
          </select>
        </div>
      
        <div class="form-group" style="position: relative">
          <label for="password"><span class="material-icons">password</span>  Password</label>
          <input
            type="password"
            id="password"
            name="password"
            class="form-control"
            placeholder="Enter your password"
            required disabled
          />
          <div class="password-tooltip" id="password-rules">
            <p id="rule-length" class="invalid"><span class="material-icons">title</span> At least 8 characters</p>
            <p id="rule-number" class="invalid"><span class="material-icons">pin</span> At least 1 number</p>
            <p id="rule-special" class="invalid"><span class="material-icons">priority_high</span> At least 1 special character (!@#$%^&*)</p>
          </div>
        </div>
      
        <div class="form-group">
          <label for="confirm-password"><span class="material-icons">password</span> Re-enter your password</label>
          <input
            type="password"
            id="confirm-password"
            name="confirm-password"
            class="form-control"
            placeholder="Confirm your password"
            required disabled
          />
          <p class="error-message" id="password-error">
            Passwords do not match.
          </p>
        </div>
      
        <button type="submit" class="primary-button" id="continue-button" disabled>
          Sign up
        </button>
      </form>
      

    <div class="return-home">
      <a href="/" class="return-home-btn">← Return to Home</a>
    </div>
  </div>

  <script src="/javascripts/register.js"></script>
</body>
</html>
