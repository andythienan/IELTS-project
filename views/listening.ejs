<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Listening Test</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
  <link href="/styles/listening.css" rel="stylesheet" />
</head>

<body>
  <header>
    Listening Test
    <div id="timer">00:10</div>
  </header>
  <div id="notification" style="display: none;">
    Test submitted successfully!
    <button id="notification-close">
      <i class="material-icons">close</i>
    </button>
  </div>
  <main>
    <div class="column" class="response-column" id="response-container">
      <h2>Your Response</h2>
      <textarea id="response-input" placeholder="Write your response here..." maxlength="5000"></textarea>
      <div class="word-count">
        Word Count: <span id="word-count">0</span>
      </div>
    </div>
      <div class="column" id="questions-container">
        <h2>Questions</h2>
        <audio id="audio-player" style="display: none;">
          <source src="/files/Listening1.mp3" type="audio/mpeg" />
          Your browser does not support the audio element.
        </audio>
        <form id="questions-form">
          <p id="question"></p>
          </div>
        </form>
      </div>
  </main>

  <script src="/javascripts/listening.js"></script>
</body>

</html>