<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lesson Library - Learn English</title>
    <link rel="stylesheet" href="/styles/styles.css">
    <link rel="stylesheet" href="/styles/typography.css">
</head>
<body class="page-lessons-library">
    <header class="header">
        <%- include('partials/header', { user: name }) %>
    </header>

    <main>
        <aside class="sidebar">
            <h1>Lesson Topics</h1>
            <ul>
                <li><a href="#">Grammar</a></li>
                <li><a href="#">Vocabulary</a></li>
                <li><a href="#">Phrasal Verbs</a></li>
                <li><a href="#">Idioms</a></li>
                <li><a href="#">Expressions</a></li>
            </ul>
        </aside>

        <div class="divider"></div>

        <section class="content">
            <!-- Announcement Section -->
            <section class="announcement">
                <h2>New Lessons Added!</h2>
                <p>Dive into our newest lesson library updates! 🌟 From mastering grammar to unlocking idiomatic expressions, we’ve got all the tools you need to become fluent in English. Start your journey today! 📚✨</p>
            </section>

            <!-- Introduction Section -->
            <section class="category">
                <h1>Lesson Library</h1>
                <p>Find carefully curated lessons tailored to help you improve your English skills. Browse through a variety of topics and learn at your own pace. Our resources are 100% free and accessible anytime.</p>
            </section>

            <!-- Grammar Lessons -->
            <section class="category">
                <h2>Grammar</h2>
                <p>Master the building blocks of English with our comprehensive grammar lessons.</p>
                <div class="grid">
                    <div class="card lesson available">
                        <h3>Lesson 1: Parts of Speech</h3>
                        <a href="/lesson/lesson1" class="btn btn-primary">Start Lesson</a>
                    </div>
                    <div class="card lesson available">
                        <h3>Lesson 2: Tenses</h3>
                        <a href="/lesson/lesson2" class="btn btn-primary">Start Lesson</a>
                    </div>
                    <div class="card lesson unavailable">
                        <h3>Lesson 3: Clauses</h3>
                        <button class="btn btn-secondary" disabled>Coming Soon</button>
                    </div>
                </div>
            </section>

            <!-- Vocabulary Lessons -->
            <section class="category">
                <h2>Vocabulary</h2>
                <p>Expand your word bank with lessons focused on commonly used English words and phrases.</p>
                <div class="grid">
                    <div class="card lesson available">
                        <h3>Lesson 1: Synonyms and Antonyms</h3>
                        <a href="/lesson/lesson4" class="btn btn-success">Start Lesson</a>
                    </div>
                    <div class="card lesson unavailable">
                        <h3>Lesson 2: Word Families</h3>
                        <button class="btn btn-secondary" disabled>Coming Soon</button>
                    </div>
                    <div class="card lesson unavailable">
                        <h3>Lesson 3: Prefixes and Suffixes</h3>
                        <button class="btn btn-secondary" disabled>Coming Soon</button>
                    </div>
                </div>
            </section>
        </section>
    </main>

    <footer class="footer">
        <%- include('partials/footer'); -%>
    </footer>
</body>
</html>
