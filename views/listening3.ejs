<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Listening Test</title>
    <!-- Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/icon?family=Material+Icons"
      rel="stylesheet"
    />
    <!-- Styles -->
    <link href="/styles/listening.css" rel="stylesheet" />
  </head>

  <body>
    <header>
      <p>Listening 3</p>
      <div id="timer"><span class="material-icons">timer</span>  00:00</div>
    </header>

    <!-- Notification Section -->
    <div id="notification" style="display: none">
      <p>Test submitted successfully!</p>
      <button id="notification-close" aria-label="Close Notification">
        <i class="material-icons">close</i>
      </button>
    </div>

    <main>
      <!-- Response Section -->
      <div class="column response-column" id="response-container">
        <h2>Note</h2>
        <textarea
          id="response-input"
          placeholder="Write your note here..."
          maxlength="5000"
        ></textarea>
        <div class="word-count">Word Count: <span id="word-count">0</span></div>
      </div>

      <!-- Questions Section -->
      <div class="column" id="questions-container">
        <h2>Questions</h2>
        <!-- Audio Player -->
        <!-- Audio Player -->
        <div id="audio-section">
          <audio id="audio-player">
            <source src="/files/Listening3.mp3" type="audio/mpeg" />
            Your browser does not support the audio element.
          </audio>
          <button id="play-audio-btn" class="btn"><span class="material-icons">play_arrow</span> Play audio</button>
        </div>

        <!-- Questions Form -->
        <form id="questions-form">
          <div id="questions-list"></div>
        </form>
      </div>
    </main>

    <!-- Scripts -->
    <script src="/javascripts/listening3.js"></script>
    <script>
      const loggedInUserId = "<%= user ? user._id : null %>";
      const questions = [
      {
      "type": "multiple-choice",
      "question": "What is the monthly rent for the three-bedroom apartment on Beetle Road?",
      "options": ["$435, including internet and utilities", "$400, including utilities but no internet", "$340, with shared facilities", "$500, meals included"],
      "answer": "$435, including internet and utilities"
    },
    {
      "type": "multiple-choice",
      "question": "Which apartment is closest to the student’s classes?",
      "options": ["The apartment on Beetle Road", "The apartment on Oakington Avenue", "The apartment on Mead Street", "The Devon Close apartment"],
      "answer": "The apartment on Oakington Avenue"
    },
    {
      "type": "t-f-ng",
      "question": "The apartment on Mead Street includes a DVD player.",
      "options": ["True", "False", "Not Given"],
      "answer": "False"
    },
    {
      "type": "t-f-ng",
      "question": "The apartment on Devon Close provides free breakfast and lunch.",
      "options": ["True", "False", "Not Given"],
      "answer": "False"
    },
    {
      "type": "multiple-choice",
      "question": "Which feature is missing in the Devon Close apartment?",
      "options": ["A bathroom inside the apartment", "A study with a lamp", "Free evening meals", "Access to a dining hall"],
      "answer": "A bathroom inside the apartment"
    },
    {
      "type": "t-f-ng",
      "question": "The student prefers the apartment on Beetle Road over the one on Devon Close.",
      "options": ["True", "False", "Not Given"],
      "answer": "Not Given"
    },
    {
      "type": "multiple-choice",
      "question": "What is the rent for a room with an air conditioner in the Oakington Avenue dormitory?",
      "options": ["$435 per month", "$400 per month", "$340 per month", "$600 per month"],
      "answer": "$400 per month"
    },
      ]
    </script>
  </body>
</html>
